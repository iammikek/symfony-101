{% extends 'base.html.twig' %}

{% block title %}{{ item.name }}{% endblock %}

{% block body %}
<article class="panel">
  <p class="eyebrow"><a href="{{ path('shop_item_list') }}">← Back to items</a></p>
  <h1>{{ item.name }}</h1>
  <dl class="detail-list">
    <div><dt>Price</dt><dd>${{ item.price }}</dd></div>
    <div><dt>Category</dt><dd>{{ item.category ? item.category.name : 'Uncategorized' }}</dd></div>
    <div><dt>Description</dt><dd>{{ item.description ?: 'No description.' }}</dd></div>
  </dl>
  <p class="muted">Same record as <a href="/items/{{ item.id }}">GET /items/{{ item.id }}</a> (JSON).</p>
</article>
{% endblock %}
