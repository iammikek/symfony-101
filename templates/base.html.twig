<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% block title %}Catalog Shop{% endblock %} · symfony-101</title>
  <link rel="stylesheet" href="{{ asset('shop/style.css') }}">
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="{{ path('shop_home') }}">Catalog Shop</a>
      <nav class="nav">
        <a href="{{ path('shop_home') }}">Home</a>
        <a href="{{ path('shop_item_list') }}">Items</a>
        <a href="/items">API</a>
      </nav>
      <div class="auth">
        {% if app.user %}
          <span class="muted">{{ app.user.userIdentifier }}</span>
          <form method="post" action="{{ path('shop_logout') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
            <button type="submit" class="link-button">Log out</button>
          </form>
        {% else %}
          <a href="{{ path('shop_login') }}">Log in</a>
        {% endif %}
      </div>
    </div>
  </header>

  <main class="container">
    {% for label, messages in app.flashes %}
      <ul class="messages">
        {% for message in messages %}
          <li class="message {{ label }}">{{ message }}</li>
        {% endfor %}
      </ul>
    {% endfor %}

    {% block body %}{% endblock %}
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="muted">
        Server-rendered Twig templates — same services as the JSON API.
      </p>
    </div>
  </footer>
</body>
</html>
